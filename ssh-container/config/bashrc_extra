
# ─────────────────────────────────────────────────────────────────────────────
# D.A.N. — Dynamic Access Node  — shell configuration
# ─────────────────────────────────────────────────────────────────────────────

# ── D.A.N. prompt (shows git branch + status) ────────────────────────────────
parse_git_branch() { git branch 2>/dev/null | grep '^*' | sed 's/* //'; }
parse_git_dirty()  { [[ -n "$(git status --short 2>/dev/null)" ]] && echo "*"; }
export PS1='\[\e[1;36m\][ D·A·N ]\[\e[0m\] \[\e[1;32m\]\u\[\e[0m\]:\[\e[1;34m\]\w\[\e[33m\]$( b=$(parse_git_branch); [ -n "$b" ] && echo " (${b}$(parse_git_dirty))")\[\e[0m\]\$ '

# ── PATH ──────────────────────────────────────────────────────────────────────
export PATH="${HOME}/.local/bin:${HOME}/bin:${HOME}/go/bin:/usr/local/go/bin:/usr/local/bin:${PATH}"
export GOPATH="${HOME}/go"

# ── Tor proxy — all outbound traffic anonymised ───────────────────────────────
export ALL_PROXY="socks5h://127.0.0.1:9050"
export all_proxy="socks5h://127.0.0.1:9050"
export SOCKS_SERVER="127.0.0.1:9050"
export NO_PROXY="localhost,127.0.0.1,::1,.local"
export no_proxy="localhost,127.0.0.1,::1,.local"

# ── Agent memory — load functions into every shell ────────────────────────────
if [[ -f /scripts/agent-memory.sh ]]; then
  source /scripts/agent-memory.sh
  # Auto-init memory directory on first login
  init_memory 2>/dev/null || true
fi

MEMORY_FILE="${HOME}/agent-memory/MEMORY.md"

# ─────────────────────────────────────────────────────────────────────────────
# AI AGENTS — free, anonymous, unrestricted
# ─────────────────────────────────────────────────────────────────────────────

# ── Online free models (via Tor + OpenRouter/Groq) ────────────────────────────
# Set: export OPENROUTER_API_KEY=sk-or-...  (free at openrouter.ai)
#      export GROQ_API_KEY=gsk_...          (free at console.groq.com)
#      export GITHUB_TOKEN=ghp_...          (free with GitHub account)

# Main agent — DeepSeek R1 (strong reasoning, less filtered than GPT)
agent() {
  log_session "deepseek-r1" 2>/dev/null || true
  torsocks aider --model openrouter/deepseek/deepseek-r1:free \
    ${MEMORY_FILE:+--read "${MEMORY_FILE}"} "$@"
}

# Fast agent — Llama 3.3 70B via Groq (very fast inference)
agent-fast() {
  log_session "llama-3.3-70b-groq" 2>/dev/null || true
  torsocks aider --model groq/llama-3.3-70b-versatile \
    ${MEMORY_FILE:+--read "${MEMORY_FILE}"} "$@"
}

# Deep reasoning — Nous Hermes 3 405B (less filtered, high capability)
agent-deep() {
  log_session "nous-hermes-3-405b" 2>/dev/null || true
  torsocks aider --model openrouter/nousresearch/hermes-3-llama-3.1-405b:free \
    ${MEMORY_FILE:+--read "${MEMORY_FILE}"} "$@"
}

# GitHub Models — GPT-4o (free with GitHub account)
agent-gh() {
  log_session "gpt-4o-github" 2>/dev/null || true
  torsocks aider --model github/gpt-4o \
    ${MEMORY_FILE:+--read "${MEMORY_FILE}"} "$@"
}

# ── Local uncensored models (no API key, no content filters, no Tor needed) ───
# Requires Ollama: curl https://ollama.ai/install.sh | sh
# Auto-installed on first boot when AUTO_INSTALL_EXTRAS=yes

agent-local() {
  # dolphin-mistral: uncensored Mistral — follows any instruction
  log_session "dolphin-mistral-local" 2>/dev/null || true
  if command -v ollama &>/dev/null; then
    aider --model ollama/dolphin-mistral \
      ${MEMORY_FILE:+--read "${MEMORY_FILE}"} "$@"
  else
    echo "Ollama not installed. Run: curl https://ollama.ai/install.sh | sh && ollama pull dolphin-mistral"
    echo "Falling back to online agent..."
    agent "$@"
  fi
}

agent-local-l3() {
  # dolphin-llama3: uncensored Llama 3
  log_session "dolphin-llama3-local" 2>/dev/null || true
  aider --model ollama/dolphin-llama3 \
    ${MEMORY_FILE:+--read "${MEMORY_FILE}"} "$@"
}

# Override bare 'aider' to always use torsocks + memory
aider() {
  torsocks "$(command -v aider || echo 'python3 -m aider')" \
    ${MEMORY_FILE:+--read "${MEMORY_FILE}"} "$@"
}

alias agents='bash /scripts/dan-agents.sh'
alias aider-help='command aider --help | less'

