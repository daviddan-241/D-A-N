# ─────────────────────────────────────────────────────────────────────────────
# WELCOME BANNER
# ─────────────────────────────────────────────────────────────────────────────
_dan_tor_status() {
  if kill -0 "$(cat /var/run/tor.pid 2>/dev/null)" 2>/dev/null; then
    echo -e "\033[1;32mTor: ACTIVE\033[0m"
  else
    echo -e "\033[1;31mTor: inactive\033[0m"
  fi
}
_dan_ollama_status() {
  if command -v ollama &>/dev/null && ollama list 2>/dev/null | grep -q "dolphin"; then
    echo -e "\033[1;32mOllama: READY (uncensored)\033[0m"
  elif command -v ollama &>/dev/null; then
    echo -e "\033[1;33mOllama: installed, no models yet\033[0m"
  else
    echo -e "\033[0;90mOllama: not installed (run AUTO_INSTALL_EXTRAS=yes)\033[0m"
  fi
}
_dan_memory_status() {
  if [[ -f "${HOME}/agent-memory/MEMORY.md" ]]; then
    local count
    count=$(grep -c '^-' "${HOME}/agent-memory/MEMORY.md" 2>/dev/null || echo 0)
    echo -e "\033[1;32mMemory: ${count} notes\033[0m"
  else
    echo -e "\033[0;90mMemory: empty\033[0m"
  fi
}

echo ""
echo -e "  \033[1;36m[ D · A · N ]\033[0m  Dynamic Access Node"
echo -e "  \033[0;32m$(date)\033[0m"
echo -e "  $(_dan_tor_status)  |  $(_dan_ollama_status)  |  $(_dan_memory_status)"
echo ""
echo -e "  Agents:  \033[1;33magent\033[0m (R1)  \033[1;33magent-local\033[0m (uncensored)  \033[1;33magent-fast\033[0m (Groq)  \033[1;33magents\033[0m (tmux)"
