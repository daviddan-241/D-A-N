# ── History ───────────────────────────────────────────────────────────────────
export HISTSIZE=50000
export HISTFILESIZE=100000
export HISTCONTROL=ignoredups:erasedups
export HISTTIMEFORMAT="%Y-%m-%d %H:%M:%S  "
shopt -s histappend
PROMPT_COMMAND="history -a; history -c; history -r; ${PROMPT_COMMAND:-}"

# ── Editor & terminal ─────────────────────────────────────────────────────────
export EDITOR=vim
export VISUAL=vim
export TERM=xterm-256color
export PAGER=less
export LESS='-R'

# ── Colors ────────────────────────────────────────────────────────────────────
export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# ── Welcome banner ────────────────────────────────────────────────────────────
echo ""
echo "  \033[1;36m[ D · A · N ]\033[0m  Dynamic Access Node"
echo "  \033[0;32m$(date)\033[0m"
TOR_STATUS=$( (kill -0 "$(cat /var/run/tor.pid 2>/dev/null)" 2>/dev/null && echo "\033[1;32mTor: ACTIVE\033[0m") || echo "\033[1;31mTor: inactive\033[0m" )
echo "  ${TOR_STATUS}  |  Type \033[1;33mtor-check\033[0m to verify anonymity"
echo "  Type \033[1;33mtmux new -s main\033[0m to start a persistent session."
echo "  Type \033[1;33mdan-status\033[0m for startup log."
echo ""
