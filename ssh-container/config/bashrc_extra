# Anonymous web search (DuckDuckGo CLI via Tor)
search() {
  if [[ $# -eq 0 ]]; then echo "Usage: search <query>"; return 1; fi
  torsocks ddgr --np --noprompt "$@" 2>/dev/null && return 0
  # ddgr fallback — build query string with sed (no python3 needed)
  local q
  q=$(printf '%s ' "$@" | sed 's/^ //; s/ $//; s/ /+/g')
  torsocks curl -sL --max-time 15 "https://html.duckduckgo.com/html/?q=${q}" \
    | sed 's/<[^>]*>//g; /^[	 ]*$/d' | head -60
}
