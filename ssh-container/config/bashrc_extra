# Fetch and extract just the text of a page (aider-friendly)
fetch-text() {
  if [[ $# -eq 0 ]]; then echo "Usage: fetch-text <url>"; return 1; fi
  torsocks curl -sL --max-time 20 "$1" \
    | python3 -c "
import sys, html, re
body = sys.stdin.read()
body = re.sub(r'<(script|style)[^>]*>.*?</\1>', '', body, flags=re.DOTALL|re.I)
body = re.sub(r'<[^>]+>', ' ', body)
body = html.unescape(body)
body = re.sub(r'\s+', ' ', body).strip()
print(body[:8000])
"
}

