# ── Local uncensored models (no API key, no content filters, no Tor needed) ───
# Requires Ollama: curl https://ollama.ai/install.sh | sh
# Auto-installed on first boot when AUTO_INSTALL_EXTRAS=yes

agent-local() {
  # dolphin-mistral: uncensored Mistral — follows any instruction
  log_session "dolphin-mistral-local" 2>/dev/null || true
  if command -v ollama &>/dev/null; then
    aider --model ollama/dolphin-mistral \
      ${MEMORY_FILE:+--read "${MEMORY_FILE}"} "$@"
  else
    echo "Ollama not installed. Run: curl https://ollama.ai/install.sh | sh && ollama pull dolphin-mistral"
    echo "Falling back to online agent..."
    agent "$@"
  fi
}

agent-local-l3() {
  # dolphin-llama3: uncensored Llama 3
  log_session "dolphin-llama3-local" 2>/dev/null || true
  aider --model ollama/dolphin-llama3 \
    ${MEMORY_FILE:+--read "${MEMORY_FILE}"} "$@"
}

# Override bare 'aider' — Tor-routed for online models, direct for local ollama
# Flat logic — no nested functions (bash -n compatible across all bash versions).
aider() {
  local mem_flag="${MEMORY_FILE:+--read ${MEMORY_FILE}}"
  local use_local=false
  local arg
  for arg in "$@"; do
    case "${arg}" in ollama/*|*/ollama*) use_local=true; break ;; esac
  done
  if [[ "${use_local}" == "true" ]]; then
    command -v aider &>/dev/null \
      && command aider ${mem_flag} "$@" \
      || python3 -m aider ${mem_flag} "$@"
  else
    command -v aider &>/dev/null \
      && torsocks command aider ${mem_flag} "$@" \
      || torsocks python3 -m aider ${mem_flag} "$@"
  fi
}

