
# ─────────────────────────────────────────────────────────────────────────────
# D.A.N. — Dynamic Access Node  — shell configuration
# ─────────────────────────────────────────────────────────────────────────────

# ── D.A.N. prompt (shows git branch + status) ────────────────────────────────
parse_git_branch() {
  git branch 2>/dev/null | grep '^*' | sed 's/* //'
}
parse_git_dirty() {
  [[ -n "$(git status --short 2>/dev/null)" ]] && echo "*"
}
export PS1='\[\e[1;36m\][ D·A·N ]\[\e[0m\] \[\e[1;32m\]\u\[\e[0m\]:\[\e[1;34m\]\w\[\e[33m\]$( b=$(parse_git_branch); [ -n "$b" ] && echo " (${b}$(parse_git_dirty))")\[\e[0m\]\$ '

# ── PATH ──────────────────────────────────────────────────────────────────────
export PATH="${HOME}/.local/bin:${HOME}/bin:${HOME}/go/bin:/usr/local/go/bin:${PATH}"
export GOPATH="${HOME}/go"

# ── Tor proxy — all outbound traffic anonymised ───────────────────────────────
# torsocks wraps individual commands at libc level (best DNS leak protection).
# ALL_PROXY covers tools that read standard proxy env vars.
export ALL_PROXY="socks5h://127.0.0.1:9050"
export all_proxy="socks5h://127.0.0.1:9050"
export SOCKS_SERVER="127.0.0.1:9050"
# Don't proxy loopback / container-internal traffic
export NO_PROXY="localhost,127.0.0.1,::1,.local"
export no_proxy="localhost,127.0.0.1,::1,.local"

# ── Core aliases ──────────────────────────────────────────────────────────────
alias ll='ls -alFh --color=auto'
alias la='ls -A --color=auto'
alias l='ls -CF --color=auto'
alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# ── Security tool aliases ─────────────────────────────────────────────────────
# Nmap
alias nmap-fast='nmap -T4 -F'
alias nmap-full='nmap -T4 -A -v'
alias nmap-udp='sudo nmap -sU -T4 --top-ports 200'
alias nmap-vuln='nmap -T4 --script vuln'
alias nmap-ping='nmap -sn'

# Gobuster (via proxychains for anonymity)
alias gb='proxychains4 gobuster dir -w ~/wordlists/SecLists/Discovery/Web-Content/common.txt'
alias gb-big='proxychains4 gobuster dir -w ~/wordlists/SecLists/Discovery/Web-Content/big.txt'

# ffuf (via proxychains for anonymity)
alias fuzz='proxychains4 ffuf -w ~/wordlists/SecLists/Discovery/Web-Content/common.txt'

# Nuclei
alias nuclei-scan='nuclei -t ~/nuclei-templates'
alias nuclei-fast='nuclei -t ~/nuclei-templates -severity high,critical'

# Hashcat
alias crack-md5='hashcat -m 0'
alias crack-ntlm='hashcat -m 1000'
alias crack-sha256='hashcat -m 1400'

# Hydra shortcuts (via proxychains)
alias hydra-ssh='proxychains4 hydra -P ~/wordlists/rockyou.txt ssh'
alias hydra-ftp='proxychains4 hydra -P ~/wordlists/rockyou.txt ftp'
alias hydra-http='proxychains4 hydra -P ~/wordlists/rockyou.txt http-get'

# ── Browser aliases ───────────────────────────────────────────────────────────
alias browser-headless='chromium --headless --no-sandbox --disable-gpu --proxy-server="socks5://127.0.0.1:9050"'
alias browser-dump='chromium --headless --no-sandbox --dump-dom --proxy-server="socks5://127.0.0.1:9050"'
alias browser-screenshot='chromium --headless --no-sandbox --screenshot --proxy-server="socks5://127.0.0.1:9050"'
alias browse='torsocks w3m'
alias fetch='torsocks curl -sL'

# ── Network aliases ───────────────────────────────────────────────────────────
alias ports='ss -tlnp'
alias connections='ss -tunp'
alias myip='torsocks curl -s https://api.ipify.org && echo'
alias localip='ip addr show | grep "inet " | gawk "{print \$2}"'
alias sniff='sudo tcpdump -i any -n'
alias sniff-http='sudo tcpdump -i any -A -s 0 "tcp port 80"'

# ── Tor aliases ───────────────────────────────────────────────────────────────
alias tor-check='echo "Checking Tor..." && torsocks curl -s https://check.torproject.org/api/ip | python3 -m json.tool'
alias tor-ip='torsocks curl -s https://api.ipify.org && echo'
alias tor-status='cat /var/log/tor/notices.log 2>/dev/null | tail -20 || tail -20 /var/log/ssh-container/tor.log 2>/dev/null'
alias tor-newid='kill -HUP $(cat /var/run/tor.pid 2>/dev/null) 2>/dev/null && echo "New Tor circuit requested" || echo "Tor not running"'
alias tor-logs='tail -f /var/log/ssh-container/tor.log'

# ── Git shortcuts (via Tor) ───────────────────────────────────────────────────
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='torsocks git push'
alias gl='git log --oneline --graph --decorate --all'
alias gd='git diff'
alias gco='git checkout'

# ── Docker shortcuts ──────────────────────────────────────────────────────────
alias d='docker'
alias dc='docker compose'
alias dps='docker ps --format "table {{.Names}}\t{{.Image}}\t{{.Status}}\t{{.Ports}}"'
alias dlogs='docker logs -f'
alias dexec='docker exec -it'

# ── Python ────────────────────────────────────────────────────────────────────
alias python='python3'
alias pip='pip3'
alias venv='python3 -m venv .venv && source .venv/bin/activate'

# ── Misc ──────────────────────────────────────────────────────────────────────
alias jf='jq .'
alias top='htop'
alias reload='source ~/.bashrc'
alias dan-status='cat /var/log/ssh-container/startup.log | tail -30'
alias dan-tools='ls /usr/local/bin/ | sort'

# ── SSH tunnel status ─────────────────────────────────────────────────────────
alias dan-connect='cat ~/.dan_ssh_connect 2>/dev/null || echo "bore tunnel not active — check /var/log/ssh-container/bore.log"'
alias dan-tunnel='tail -20 /var/log/ssh-container/cloudflared.log 2>/dev/null || echo "Cloudflare tunnel log not found"'
alias dan-bore='tail -20 /var/log/ssh-container/bore.log 2>/dev/null || echo "bore log not found"'
alias git-sync='bash /scripts/dotfiles-sync.sh'
alias dan-autopush='cat /var/log/ssh-container/autopush.log 2>/dev/null | tail -20'

