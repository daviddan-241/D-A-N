# ─────────────────────────────────────────────────────────────────────────────
# D.A.N. — Dynamic Access Node
# Environment configuration — copy to .env before running
# NEVER commit .env to source control
# ─────────────────────────────────────────────────────────────────────────────

# ── Developer user ────────────────────────────────────────────────────────────
DEV_USER=devuser

# ── Match your host UID/GID to avoid volume permission issues ─────────────────
# Run `id` on your host to find these values
DEV_UID=1000
DEV_GID=1000

# ── Exposed ports ─────────────────────────────────────────────────────────────
SSH_PORT=2222        # SSH access
TTYD_PORT=7681       # Web terminal (ttyd)

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=UTC

# ── Web terminal authentication ───────────────────────────────────────────────
# Used for basic auth on the ttyd web terminal at :7681
# Change these before exposing the port publicly
WEB_TERMINAL_USER=dan
WEB_TERMINAL_PASS=changeme_use_strong_password

# ── First-boot extra tool install ─────────────────────────────────────────────
# Set to "yes" to auto-install Metasploit, SecLists, Sherlock, BeEF etc.
# on first container start. Takes 5-15 minutes. Safe to leave as "no"
# and install manually inside the container later.
AUTO_INSTALL_EXTRAS=no
