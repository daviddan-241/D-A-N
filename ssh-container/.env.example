# ─────────────────────────────────────────────────────────────────────────────
# DevBox environment configuration
# Copy to .env and edit before running: cp .env.example .env
# NEVER commit .env to source control
# ─────────────────────────────────────────────────────────────────────────────

# ── Non-root developer username (must match AllowUsers in sshd_config) ────────
DEV_USER=devuser

# ── User/group IDs (match your host UID to avoid volume permission issues) ───
# Run `id` on your host to find your UID/GID
DEV_UID=1000
DEV_GID=1000

# ── Host port to expose SSH on ────────────────────────────────────────────────
# Change from 2222 to avoid conflicts if needed
SSH_PORT=2222

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=UTC
